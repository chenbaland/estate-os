# =============================================================================
# EstateOS Environment Configuration
# Copy to .env and fill in values: cp .env.example .env
# =============================================================================

# --- Django Core ---
SECRET_KEY=change-me-to-a-secure-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
APP_LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
DB_NAME=estateos
DB_USER=estateos
DB_PASSWORD=estateos
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=600

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CHANNEL_REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# --- Celery (RabbitMQ broker + Redis result backend) ---
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# --- Elasticsearch / OpenSearch ---
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_AUTOSYNC=true
ELASTICSEARCH_AUTO_REFRESH=true

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_SIGNING_KEY=

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost

# --- Multi-tenant ---
TENANT_HEADER=X-Estate-Id
TENANT_SLUG_HEADER=X-Tenant-Slug

# --- AWS S3 (production) ---
USE_S3=false
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=eu-west-1
AWS_S3_CUSTOM_DOMAIN=
AWS_QUERYSTRING_AUTH=false

# --- Payment Providers ---
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email ---
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@estateos.app

# --- Notifications ---
SMS_PROVIDER=termii
SMS_API_KEY=
WHATSAPP_API_KEY=
FCM_SERVER_KEY=

# --- OAuth (Google / Apple) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_OAUTH_CLIENT_ID=
APPLE_OAUTH_TEAM_ID=
APPLE_OAUTH_KEY_ID=
APPLE_OAUTH_PRIVATE_KEY=
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost/ws
FRONTEND_URL=http://localhost:3000
FRONTEND_PORT=3000

# --- Docker Compose Ports ---
POSTGRES_PORT=5432
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
ELASTICSEARCH_PORT=9200
BACKEND_PORT=8000
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Production Overrides ---
ECR_REGISTRY=
IMAGE_TAG=latest
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000

# --- Monitoring (production compose) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GRAFANA_PORT=3001

# --- Rate Limiting ---
RATELIMIT_ENABLE=true
